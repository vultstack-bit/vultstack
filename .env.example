# ─────────────────────────────────────────────────────────────────────────────
# Vultstack CRM — environment variables
# Copy to `.env.local` for local dev, and set the same keys in Vercel for prod.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core URLs ────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (no trailing slash)
NEXT_PUBLIC_SERVER_URL=https://www.vultstack.com
NEXT_PUBLIC_SITE_URL=https://www.vultstack.com
NEXT_PUBLIC_BASE_URL=https://www.vultstack.com

# ── Supabase (database + auth) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Postgres connection string (Payload uses this — Supabase "Connection string" → URI)
DATABASE_URL=postgres://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# ── Payload CMS ──────────────────────────────────────────────────────────────
# Long random string — `openssl rand -base64 32`
PAYLOAD_SECRET=CHANGE_ME_RANDOM_SECRET

# ── Admin bootstrap ──────────────────────────────────────────────────────────
# The email that gets admin role on first CRM login
NEXT_PUBLIC_ADMIN_EMAIL=admin@vultstack.com

# ── Branding / contact (shown in emails, previews, social mockups) ────────────
NEXT_PUBLIC_COMPANY_NAME=Vultstack
NEXT_PUBLIC_SOCIAL_HANDLE=vultstack
NEXT_PUBLIC_CONTACT_PHONE=
CRM_CONTACT_PHONE=
CRM_CONTACT_EMAIL=info@vultstack.com
# Full "From" header for outbound CRM email, e.g. "Vultstack <info@vultstack.com>"
CRM_FROM_EMAIL=Vultstack <info@vultstack.com>
CRM_COMPANY_ADDRESS=
# AI caption generator brand context
SOCIAL_BRAND_DESCRIPTION=Vultstack, a modern company
SOCIAL_BRAND_VOICE=Professional yet approachable, knowledgeable, customer-focused.

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_YOUR_RESEND_KEY
FROM_EMAIL=noreply@vultstack.com
NEXT_PUBLIC_FROM_EMAIL=hello@vultstack.com
LEAD_NOTIFICATION_EMAIL=leads@vultstack.com
# Optional — public Google review link for the review-request email
GOOGLE_REVIEW_URL=

# ── AI (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY

# ── Secrets / security ───────────────────────────────────────────────────────
# 32-byte key for encrypting stored OAuth tokens — `openssl rand -hex 32`
TOKEN_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS
# Bearer secret protecting the Vercel cron endpoints
CRON_SECRET=CHANGE_ME_RANDOM
# Shared secret for the internal email-leads sync trigger
INTERNAL_SYNC_SECRET=CHANGE_ME_RANDOM
# Shared secret for the public lead webhook
WEBHOOK_SECRET=CHANGE_ME_RANDOM

# ── Rate limiting (Upstash Redis) — optional ─────────────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Vercel Blob storage (file/media uploads) ─────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Google (Calendar + Gmail OAuth, Maps) — optional ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_API_KEY=

# ── Social OAuth — optional, per platform you connect ─────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── SMS (Twilio) — optional, not yet wired for sending ───────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
